        <div class="remedy-tags">
          ${d.tags.map(t=>`<span class="rtag">${t}</span>`).join('')}
          <span class="rtag tea">☕ ${d.tea}</span>
        </div>
      </div>
      <div class="remedy-shop">
        <span class="shop-label">Shop</span>
        ${hAmzLink(d.amazon,'Amazon')}
        ${hAmzLink(d.snap,'SNAP/EBT Eligible','snap')}
      </div>
      ${d.alt?`<div class="alt-section">
        <div class="alt-label">Alternative Pick</div>
        <div class="alt-row">
          <span>${d.alt.emoji}</span>
          <span class="alt-name">${d.alt.food}</span>
          <span class="alt-benefit">— ${d.alt.benefit}</span>
          ${hAmzLink(d.alt.amazon,'Amazon')}
          ${hAmzLink(d.alt.snap,'SNAP/EBT','snap')}
        </div>
      </div>`:''}
    </div>`;
  }).join('');

  let intro = `Based on your symptoms — <em>${symptomNames}</em> — here is your personalized food remedy plan, drawing from nutritional science and traditional wellness. Every recommendation below has a SNAP/EBT-eligible option so everyone can access nature's medicine.`;
  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,
        system:`You are a warm, inclusive, knowledgeable nutritionist. Write a brief 2-3 sentence personalized intro (no lists, no headers) for someone experiencing the given symptoms. Be specific to their symptoms. Keep language warm, accessible, and encouraging. Mention that SNAP/EBT-eligible options are available so everyone has access. End with an uplifting note about food as medicine.`,
        messages:[{role:'user',content:`My symptoms are: ${symptomNames}. Write a personalized intro for my food remedy plan.`}]
      })
    });
    const data = await resp.json();
    intro = data.content?.[0]?.text || intro;
  } catch(e){}

  const table = `<div style="margin-top:52px">
    <div class="section-label">Quick Comparison — Bonus Remedies</div>
    <div class="table-wrap"><table class="remedy-table">
      <thead><tr><th>Issue</th><th>Recommended Food</th><th>Key Benefit</th><th>Shop Options</th></tr></thead>
      <tbody>${H_TABLE.map(r=>`<tr>
        <td>${r.emoji} ${r.issue}</td><td>${r.food}</td><td>${r.benefit}</td>
        <td><div class="tbl-links">${hTblAmz(r.amazon,'Amazon','amazon')}${hTblAmz(r.snap,'SNAP','snap')}</div></td>
      </tr>`).join('')}</tbody>
    </table></div>
  </div>`;

  const snapCallout = `<div class="snap-callout">
    <span class="snap-callout-icon">🛒</span>
    <div>
      <h3>About SNAP/EBT on Amazon</h3>
      <p>Amazon accepts SNAP/EBT benefits for eligible grocery items in most U.S. states. Every "SNAP/EBT Eligible" link above searches Amazon Fresh and Amazon Grocery for items purchasable with your benefits card. Look for the <strong>"SNAP EBT eligible"</strong> badge on listings. <a href="https://www.amazon.com/snap-ebt/b/?node=19097785011" target="_blank">Learn more about Amazon SNAP ↗</a></p>
    </div>
  </div>`;

  document.getElementById('h-loading').style.display = 'none';
  const el = document.getElementById('h-results');
  el.style.display = 'block';
  el.innerHTML = `
    <div class="section-label">Your personalized remedy plan</div>
    <div class="intro-card">${intro}</div>
    ${cards}${snapCallout}${table}
    <footer style="margin-top:52px">
      <p>Harvest Heal · Powered by Claude AI · This tool is for informational purposes only and does not constitute medical advice.<br>
      Always consult a healthcare professional for persistent or serious symptoms.<br>
      SNAP/EBT eligibility on Amazon varies by state and product.</p>
    </footer>`;
  document.getElementById('h-getBtn').disabled = false;
  el.scrollIntoView({behavior:'smooth', block:'start'});
}

hRenderSymptoms();
</script>
</body>
</html>
